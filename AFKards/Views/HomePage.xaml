<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AFKards.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AFKards.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AFKards.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Riga 0: Toolbar in alto -->
            <RowDefinition Height="*"/>
            <!-- Riga 1: Lista Giochi -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- TOOLBAR SUPERIORE                          -->
        <!-- ========================================== -->
        <Border Grid.Row="0" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" 
                CornerRadius="8" 
                Padding="16,8" 
                Margin="0,0,0,16">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Spazio Info Utente -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spazio Vuoto (spinge i bottoni a destra) -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Spazio Bottoni -->
                </Grid.ColumnDefinitions>

                <!-- Label di stato e nome utente -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE77B;" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Stato Utente: " FontWeight="SemiBold"/>
                    <TextBlock x:Name="LblUserStatus" Text="In attesa..." Margin="4,0,0,0" Foreground="Gray"/>
                </StackPanel>

                <!-- Pulsanti di Azione -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button x:Name="BtnRefresh" Content="🔄 Aggiorna Lista" Click="BtnRefresh_Click" />
                    <Button x:Name="BtnStartFarming" Content="▶ Avvia Farming" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- GRIDVIEW (La nostra "ListView" moderna)    -->
        <!-- ========================================== -->
        <GridView Grid.Row="1" 
                  x:Name="GvGames" 
                  SelectionMode="Single"
                  ShowsScrollingPlaceholders="True">

            <!-- Definizione della Card del singolo gioco -->
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:GameBadgeInfo">

                    <!-- Bordo arrotondato della Card -->
                    <Border Width="180" Height="140" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Margin="6">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="80"/>
                                <!-- Header Immagine -->
                                <RowDefinition Height="*"/>
                                <!-- Titolo e Carte -->
                            </Grid.RowDefinitions>

                            <!-- Immagine di copertina (Il binding avverrà più avanti) -->
                            <Image Grid.Row="0" 
                                   Stretch="UniformToFill" 
                                   VerticalAlignment="Top" />
                            <!-- Nota: CornerRadius solo in alto per seguire il bordo del rettangolo -->

                            <StackPanel Grid.Row="1" Padding="12,8" Spacing="6">

                                <!-- Nome del Gioco -->
                                <TextBlock Text="{x:Bind Title}" 
                                           FontSize="13" 
                                           FontWeight="SemiBold" 
                                           TextTrimming="CharacterEllipsis" 
                                           MaxLines="1"/>

                                <!-- Generatore dei rettangolini per le carte -->
                                <!-- Usa un ItemsControl orizzontale al posto della ProgressBar -->
                                <ItemsControl ItemsSource="{x:Bind CardRectangles}" ToolTipService.ToolTip="{x:Bind ToolTipText}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Il singolo "rettangolino" carta -->
                                            <Border Width="12" Height="18" 
                                                    Background="{ThemeResource SystemAccentColorLight2}" 
                                                    CornerRadius="2" 
                                                    BorderThickness="1"
                                                    BorderBrush="{ThemeResource SystemAccentColorDark1}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Grid>
                    </Border>

                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>